generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// 운동 세션 (날짜별 1회 운동)
model WorkoutSession {
  id        Int        @id @default(autoincrement())
  date      DateTime   @default(now())
  bodyPart  String     // shoulder, chest, back, legs, arms
  notes     String?
  exercises Exercise[]
}

// 종목 (벤치프레스, 스쿼트 등)
model Exercise {
  id        Int             @id @default(autoincrement())
  name      String
  order     Int             @default(0)
  session   WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId Int
  sets      Set[]
}

// 세트별 기록
model Set {
  id           Int      @id @default(autoincrement())
  setNumber    Int
  weight       Float
  reps         Int
  rir          Int?     // Reps In Reserve (선택)
  stimulation  Int?     // 자극 점수 1~10
  pump         Int?     // 펌핑 점수 1~10
  exercise     Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId   Int
}

// 식단 + 보충제 타이밍
model DietLog {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique @default(now())
  breakfastCarbs  Int      @default(1) // 0~2
  lunchCarbs      Int      @default(1) // 0~2
  dinnerCarbs     Int      @default(1) // 0~2
  workoutTime     String?  // "17:00"
  beetTime        String?  // 비트 섭취 시간 "14:00"
  arginineTime    String?  // 아르기닌 섭취 시간 "16:30"
  caffeineTime    String?  // 카페인 섭취 시간 "16:30"
  notes           String?
}

// 컨디션 / 상태 기록
model ConditionLog {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique @default(now())
  weight      Float?   // kg
  sleepHours  Float?   // 수면 시간
  fatigue     Int?     // 피로도 1~10
  condition   Int?     // 컨디션 1~10
  notes       String?
}
